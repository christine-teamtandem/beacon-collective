# Resend — paste your API key (starts with re_) to enable direct delivery.
# Without this, emails fall back to the Lovable Cloud queue pipeline.
RESEND_API_KEY="re_YOUR_KEY_HERE"

# Optional: override the sender address (must be verified in your Resend account).
# Default: Freebleeders Mentorship Hub <noreply@mentorship.freebleeders.org>
# RESEND_FROM_EMAIL="Freebleeders Mentorship Hub <freebleeders@gmail.com>"

# Zoom OAuth — create a User-managed OAuth app at marketplace.zoom.us
# Redirect URI to register in Zoom: https://mentorship.freebleeders.org/api/public/zoom/callback
ZOOM_CLIENT_ID="your_zoom_client_id_here"
ZOOM_CLIENT_SECRET="your_zoom_client_secret_here"

# Public URL of this deployment — used to build the Zoom OAuth redirect URI.
# Change this to http://localhost:5173 for local development.
PUBLIC_SITE_URL="https://mentorship.freebleeders.org"

# Weekly Zoom check-in hook — random secret; never expose to the browser.
# Admin → Diagnostics → Run Zoom weekly check-ins uses this server-side.
# Generate: openssl rand -hex 32
CHECKIN_WEBHOOK_SECRET="your_random_secret_here"
